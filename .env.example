# Conexão com o PostgreSQL. Em produção (Docker), o host é o nome do serviço
# do banco no docker-compose ("db").
DATABASE_URL="postgresql://kob:TROQUE_ESTA_SENHA@db:5432/relatorioskob?schema=public"

# Chave secreta para assinar a sessão (JWT). Gere uma com:  openssl rand -base64 32
SESSION_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_DE_32_BYTES"

# Credenciais do primeiro Super Admin, criadas pelo seed na primeira subida.
SEED_SUPER_ADMIN_EMAIL="admin@kobdigital.online"
SEED_SUPER_ADMIN_PASSWORD="TROQUE_ESTA_SENHA_FORTE"
SEED_SUPER_ADMIN_NOME="Administrador"

# Variáveis usadas pelo docker-compose para subir o container do Postgres.
POSTGRES_USER="kob"
POSTGRES_PASSWORD="TROQUE_ESTA_SENHA"
POSTGRES_DB="relatorioskob"
